# Dashboard connector endpoint (get from your dashboard operator)
DASHBOARD_URL=wss://dashboard.example.com/api/connector

# One-time token issued by POST /api/instances (mode=connector)
INSTANCE_TOKEN=paste-the-token-here

# Local OpenClaw gateway URL (defaults to ws://localhost:18789)
GATEWAY_URL=ws://localhost:18789

# Where to persist the local device identity + paired token
STATE_DIR=./state
